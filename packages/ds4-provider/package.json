{
  "name": "@lgrammel/ds4-provider",
  "version": "0.0.4",
  "description": "DS4 provider for the Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "ds4": {
    "repo": "https://github.com/antirez/ds4.git",
    "commit": "613e9b2c9b78c09ac9f622bb8ece81c99989ead6"
  },
  "files": [
    "dist",
    "ds4/ds4.c",
    "ds4/ds4.h",
    "ds4/ds4_gpu.h",
    "ds4/ds4_metal.m",
    "ds4/LICENSE",
    "ds4/metal",
    "native",
    "scripts",
    "binding.gyp"
  ],
  "scripts": {
    "install": "node scripts/postinstall.cjs",
    "prepack": "pnpm run vendor:ds4 && pnpm run build:ts",
    "vendor:ds4": "node scripts/vendor-ds4.cjs",
    "build:native": "node-gyp rebuild",
    "build:ts": "tsc",
    "build": "pnpm run vendor:ds4 && pnpm run build:native && pnpm run build:ts",
    "clean": "rm -rf dist build",
    "test": "pnpm run test:js && pnpm run test:native",
    "test:js": "vitest run",
    "test:native": "pnpm run vendor:ds4 && mkdir -p build/test && c++ -std=c++17 -Wall -Wextra -Ids4 test/binding-helpers.test.cpp -o build/test/binding-helpers.test && build/test/binding-helpers.test",
    "typecheck": "tsc --noEmit -p tsconfig.check.json"
  },
  "keywords": [
    "ai",
    "ai-sdk",
    "ds4",
    "deepseek",
    "language-model",
    "vercel"
  ],
  "author": "Lars Grammel",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/provider": "4.0.0-canary.16",
    "node-addon-api": "^8.0.0",
    "node-gyp": "^11.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.6"
  }
}
